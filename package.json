{
  "name": "choomfie-monorepo",
  "private": true,
  "version": "0.5.0",
  "description": "Personal AI agent channel plugin for Claude Code — Discord bridge with persistent memory and skills.",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*",
    "plugins/*"
  ],
  "scripts": {
    "start": "bun install --no-summary && bun packages/core/server.ts",
    "test": "bun test",
    "test:all": "bun test packages/*/test/ test/",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint-staged": "lint-staged",
    "prepare": "husky || true",
    "deploy-commands": "bun packages/core/scripts/deploy-commands.ts",
    "daemon": "bun packages/core/daemon.ts"
  },
  "lint-staged": {
    "*.ts": "eslint --fix"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.87",
    "@choomfie/browser": "workspace:*",
    "@choomfie/core": "workspace:*",
    "@choomfie/reaction-roles": "workspace:*",
    "@choomfie/shared": "workspace:*",
    "@choomfie/socials": "workspace:*",
    "@choomfie/tutor": "workspace:*",
    "@choomfie/voice": "workspace:*",
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.19.2",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@ricky0123/vad-node": "^0.0.3",
    "@sglkc/kuroshiro-analyzer-kuromoji": "^1.0.1",
    "discord.js": "^14.16.0",
    "kuroshiro": "^1.2.0",
    "onnxruntime-node": "^1.24.3",
    "opusscript": "^0.1.1",
    "playwright": "^1.58.2",
    "prism-media": "^1.3.5",
    "rettiwt-api": "^6.2.1",
    "snoowrap": "^1.23.0",
    "sodium-native": "^5.1.0",
    "ts-fsrs": "^5.3.1",
    "wanakana": "^5.3.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "typescript": "^6.0.3"
  },
  "trustedDependencies": [
    "onnxruntime-node"
  ]
}
