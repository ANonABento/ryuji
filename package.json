{
  "name": "choomfie",
  "private": true,
  "version": "0.5.0",
  "description": "Hermes-based personal agent distribution with a legacy Bun/Claude Code runtime.",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "legacy/bun/packages/*",
    "legacy/bun/plugins/*"
  ],
  "scripts": {
    "start": "bin/choomfie",
    "setup": "bin/choomfie setup",
    "doctor": "bin/choomfie doctor",
    "hermes": "bin/choomfie hermes",
    "legacy": "bin/choomfie legacy",
    "legacy:start": "bun install --no-summary && bun legacy/bun/packages/core/server.ts",
    "legacy:start:local": "bun install --no-summary && bun legacy/bun/packages/core/server.ts --local",
    "test": "bun test legacy/bun/packages/*/test/ legacy/bun/plugins/*/test/ test/",
    "test:all": "bun test legacy/bun/packages/*/test/ test/",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint-staged": "lint-staged",
    "prepare": "husky || true",
    "deploy-commands": "bun legacy/bun/packages/core/scripts/deploy-commands.ts",
    "daemon": "bun legacy/bun/packages/core/daemon.ts",
    "install:launchd": "legacy/bun/packages/core/scripts/install-launchd.sh"
  },
  "lint-staged": {
    "*.ts": "eslint --fix"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.87",
    "@choomfie/browser": "workspace:*",
    "@choomfie/core": "workspace:*",
    "@choomfie/shared": "workspace:*",
    "@choomfie/socials": "workspace:*",
    "@choomfie/tutor": "workspace:*",
    "@choomfie/voice": "workspace:*",
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.19.2",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@ricky0123/vad-node": "^0.0.3",
    "@sglkc/kuroshiro-analyzer-kuromoji": "^1.0.1",
    "discord.js": "^14.16.0",
    "kuroshiro": "^1.2.0",
    "onnxruntime-node": "^1.24.3",
    "opusscript": "^0.1.1",
    "playwright": "^1.58.2",
    "prism-media": "^1.3.5",
    "rettiwt-api": "^6.2.1",
    "snoowrap": "^1.23.0",
    "sodium-native": "^5.1.0",
    "ts-fsrs": "^5.3.1",
    "wanakana": "^5.3.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "eslint": "^10.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  },
  "trustedDependencies": [
    "onnxruntime-node"
  ]
}
