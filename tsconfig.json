{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": false,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "types": ["bun"],
    "paths": {
      "@choomfie/shared": ["legacy/bun/packages/shared/index.ts"],
      "@choomfie/voice": ["legacy/bun/plugins/voice/index.ts"],
      "@choomfie/browser": ["legacy/bun/plugins/browser/index.ts"],
      "@choomfie/socials": ["legacy/bun/plugins/socials/index.ts"],
      "@choomfie/tutor": ["legacy/bun/plugins/tutor/index.ts"]
    }
  },
  "include": ["legacy/bun/packages/**/*.ts", "legacy/bun/plugins/**/*.ts"],
  "exclude": [
    "node_modules",
    "legacy/bun/packages/core/daemon-*.ts",
    "legacy/bun/packages/core/test/lesson-mode-picker.test.ts",
    "legacy/bun/packages/core/test/chart-exercise.test.ts"
  ]
}
