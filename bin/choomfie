#!/usr/bin/env bash
# Launch Choomfie — Claude Code Channels plugin for Discord
#
# Usage:
#   choomfie          # start normally
#   choomfie --tmux   # start in a detached tmux session

set -euo pipefail

CHOOMFIE_DIR="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || realpath "$0")")/.." && pwd)"

# Ensure dependencies are installed
if [ ! -d "$CHOOMFIE_DIR/node_modules" ]; then
  echo "Installing dependencies..."
  (cd "$CHOOMFIE_DIR" && bun install --no-summary)
fi

if [ "${1:-}" = "--tmux" ]; then
  if ! command -v tmux &>/dev/null; then
    echo "Error: tmux not found. Install with: brew install tmux"
    exit 1
  fi
  if tmux has-session -t choomfie 2>/dev/null; then
    echo "Choomfie session already running. Attaching..."
    tmux attach -t choomfie
  else
    tmux new-session -d -s choomfie "claude --dangerously-load-development-channels server:choomfie"
    echo "Choomfie started in tmux session. Attaching..."
    tmux attach -t choomfie
  fi
else
  exec claude --dangerously-load-development-channels server:choomfie
fi
