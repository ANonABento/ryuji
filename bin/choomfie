#!/usr/bin/env bash
# Hermes-first Choomfie launcher.

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || realpath "$0")")/.." && pwd)"
HERMES_HOME="${CHOOMFIE_HERMES_HOME:-$HOME/.choomfie-hermes}"
PROFILE_NAME="${CHOOMFIE_HERMES_PROFILE:-choomfie}"
OVERLAY_DIR="${CHOOMFIE_HERMES_OVERLAY:-$ROOT_DIR/hermes-overlay}"
CLAUDE_DATA_DIR="${CHOOMFIE_DATA_DIR:-$HOME/.claude/plugins/data/choomfie-inline}"

usage() {
  cat <<EOF
Usage:
  choomfie                  Start Hermes gateway for the Choomfie profile
  choomfie start [args...]  Start Hermes gateway for the Choomfie profile
  choomfie status [args...] Show Hermes gateway status
  choomfie stop [args...]   Stop Hermes gateway for this profile
  choomfie restart [args...] Restart Hermes gateway for this profile
  choomfie install [args...] Install Hermes gateway service
  choomfie uninstall [args...] Uninstall Hermes gateway service
  choomfie list [args...]   List Hermes gateways
  choomfie setup [args...]  Run Hermes gateway setup
  choomfie migrate-legacy [args...] Run Hermes gateway legacy migration
  choomfie chat             Open Hermes chat for the Choomfie profile
  choomfie configure-discord Configure Discord token/allowlist for both runtimes
  choomfie doctor           Check Hermes/overlay setup
  choomfie sync             Sync overlay files into isolated Hermes state
  choomfie update           Pull overlay changes into isolated Hermes state
  choomfie reset [scope]    Wipe stored state (interactive picker if scope omitted).
                            Scopes: core, archival, memory, reminders, birthdays,
                            webhooks, all. Local destructive command; stops Choomfie if running.
  choomfie claude-code [args...] Start the Claude Code-powered runtime
  choomfie claude [args...]      Alias for claude-code

Stop scope:
  choomfie stop targets the Choomfie profile gateway. Hermes flags such as
  --all or --system can broaden scope; check before confirming them.

Environment:
  CHOOMFIE_HERMES_HOME      Defaults to $HOME/.choomfie-hermes
  CHOOMFIE_HERMES_PROFILE   Defaults to choomfie
  CHOOMFIE_DATA_DIR         Defaults to $HOME/.claude/plugins/data/choomfie-inline
  HERMES_BIN                Defaults to hermes
EOF
}

claude_code() {
  exec "$ROOT_DIR/bin/choomfie-claude-code" "$@"
}

hermes_cmd() {
  local hermes_bin="${HERMES_BIN:-hermes}"
  HERMES_HOME="$HERMES_HOME" "$hermes_bin" -p "$PROFILE_NAME" "$@"
}

yaml_section_bool_is_true() {
  local file="$1"
  local section="$2"
  local key="$3"
  awk -F: -v section="$section" -v key="$key" '
    $1 ~ "^" section "$" { in_section = 1; next }
    in_section && $0 ~ "^[^[:space:]]" { in_section = 0 }
    in_section && $1 ~ "^[[:space:]]*" key "[[:space:]]*$" {
      value = tolower($2)
      sub(/[[:space:]]*#.*/, "", value)
      gsub(/[[:space:]]+/, "", value)
      if (value == "true") found = 1
    }
    END { exit(found ? 0 : 1) }
  ' "$file"
}

yaml_section_number_value() {
  local file="$1"
  local section="$2"
  local key="$3"
  awk -F: -v section="$section" -v key="$key" '
    $1 ~ "^" section "$" { in_section = 1; next }
    in_section && $0 ~ "^[^[:space:]]" { in_section = 0 }
    in_section && $1 ~ "^[[:space:]]*" key "[[:space:]]*$" {
      value = $2
      sub(/[[:space:]]*#.*/, "", value)
      gsub(/[[:space:]]+/, "", value)
      print value
      exit
    }
  ' "$file"
}

gateway_cmd() {
  local action="$1"
  shift || true
  sync_overlay
  hermes_cmd gateway "$action" "$@"
}

apply_profile_defaults() {
  if ! command -v "${HERMES_BIN:-hermes}" >/dev/null 2>&1; then
    echo "Skipping profile defaults: hermes CLI not found" >&2
    return 0
  fi

  hermes_cmd config set model.default gpt-5.3-codex-spark >/dev/null
  hermes_cmd config set model.provider openai-codex >/dev/null
  hermes_cmd config set sessions.auto_prune true >/dev/null
  hermes_cmd config set sessions.retention_days 30 >/dev/null
  hermes_cmd config set compression.enabled true >/dev/null
  hermes_cmd config set compression.threshold 0.5 >/dev/null
  hermes_cmd config set compression.target_ratio 0.2 >/dev/null
  hermes_cmd config set compression.protect_last_n 20 >/dev/null
  hermes_cmd config set agent.gateway_auto_continue_freshness 900 >/dev/null
  hermes_cmd config set agent.max_turns 50 >/dev/null
  hermes_cmd config set agent.personalities.choomfie.description "Default Choomfie voice." >/dev/null
  hermes_cmd config set agent.personalities.choomfie.system_prompt "Be casual, friendly, and fun. Talk like a cyberpunk buddy; use slang, be direct, and be a ride-or-die friend." >/dev/null
  hermes_cmd tools enable --platform discord web terminal file skills todo memory session_search clarify cronjob messaging >/dev/null || true
  hermes_cmd tools disable --platform discord browser code_execution vision image_gen tts delegation computer_use >/dev/null || true
}

sync_and_harden() {
  sync_overlay
  apply_profile_defaults
}

set_env_value() {
  local file="$1"
  local key="$2"
  local value="$3"
  local tmp

  mkdir -p "$(dirname "$file")"
  tmp="$(mktemp)"
  if [ -f "$file" ]; then
    awk -v key="$key" -v value="$value" '
      BEGIN { done = 0 }
      $0 ~ "^" key "=" {
        print key "=" value
        done = 1
        next
      }
      { print }
      END {
        if (!done) print key "=" value
      }
    ' "$file" > "$tmp"
  else
    printf '%s=%s\n' "$key" "$value" > "$tmp"
  fi
  mv "$tmp" "$file"
  chmod 600 "$file"
}

read_env_value() {
  local file="$1"
  local key="$2"
  [ -f "$file" ] || return 1
  awk -F= -v key="$key" '$1 == key { print substr($0, length(key) + 2); exit }' "$file"
}

detect_discord_owner() {
  local token="$1"
  local app_json
  command -v curl >/dev/null 2>&1 || return 1
  app_json="$(curl -s -H "Authorization: Bot $token" https://discord.com/api/v10/oauth2/applications/@me 2>/dev/null || true)"
  echo "$app_json" | grep -o '"owner"[^}]*"id"[^"]*"[^"]*"' | grep -o '"id":"[^"]*"' | head -1 | cut -d'"' -f4
}

configure_discord() {
  local claude_env="$CLAUDE_DATA_DIR/.env"
  local profile_dir="$HERMES_HOME/profiles/$PROFILE_NAME"
  local hermes_env="$profile_dir/.env"
  local token="${DISCORD_TOKEN:-${DISCORD_BOT_TOKEN:-}}"
  local owner_id=""
  local non_interactive=false

  for arg in "$@"; do
    case "$arg" in
      --non-interactive) non_interactive=true ;;
      *) echo "Unknown configure-discord option: $arg" >&2; return 2 ;;
    esac
  done

  mkdir -p "$CLAUDE_DATA_DIR" "$profile_dir"

  if [ -z "$token" ]; then
    token="$(read_env_value "$claude_env" DISCORD_TOKEN || true)"
  fi
  if [ -z "$token" ]; then
    token="$(read_env_value "$hermes_env" DISCORD_BOT_TOKEN || true)"
  fi

  if [ -z "$token" ] && [ "$non_interactive" = false ]; then
    echo ""
    echo "You need a Discord bot token. If you do not have one yet:"
    echo "  1. Go to https://discord.com/developers/applications"
    echo "  2. Create New Application > Bot > Reset Token > Copy"
    echo "  3. Enable MESSAGE CONTENT INTENT under Bot > Privileged Intents"
    echo "  4. Invite bot: OAuth2 > URL Generator > bot scope > Send Messages + Read Message History"
    echo ""
    read -rp "Paste your Discord bot token (or press Enter to skip): " token
  fi

  if [ -z "$token" ]; then
    echo "Discord token not configured. Re-run 'choomfie configure-discord' when ready."
    return 0
  fi

  set_env_value "$claude_env" DISCORD_TOKEN "$token"
  set_env_value "$hermes_env" DISCORD_BOT_TOKEN "$token"
  set_env_value "$hermes_env" CHOOMFIE_LEGACY_DB "$CLAUDE_DATA_DIR/choomfie.db"

  if [ -f "$CLAUDE_DATA_DIR/access.json" ] && grep -q '"owner"' "$CLAUDE_DATA_DIR/access.json"; then
    owner_id="$(grep -o '"owner"[[:space:]]*:[[:space:]]*"[^"]*"' "$CLAUDE_DATA_DIR/access.json" | cut -d'"' -f4)"
  else
    owner_id="$(detect_discord_owner "$token" || true)"
    if [ -n "$owner_id" ]; then
      cat > "$CLAUDE_DATA_DIR/access.json" <<EOJSON
{
  "policy": "allowlist",
  "owner": "$owner_id",
  "allowed": ["$owner_id"]
}
EOJSON
      chmod 600 "$CLAUDE_DATA_DIR/access.json"
    fi
  fi

  if [ -n "$owner_id" ]; then
    set_env_value "$hermes_env" DISCORD_ALLOWED_USERS "$owner_id"
    echo "Discord configured for owner $owner_id."
  else
    echo "Discord token configured. Set DISCORD_ALLOWED_USERS in $hermes_env before starting Hermes mode."
  fi
}

doctor() {
  local ok=true
  local profile_dir="$HERMES_HOME/profiles/$PROFILE_NAME"
  local config_file="$profile_dir/config.yaml"
  local env_file="$profile_dir/.env"
  echo "Choomfie Hermes doctor"
  echo "  repo: $ROOT_DIR"
  echo "  overlay: $OVERLAY_DIR"
  echo "  hermes home: $HERMES_HOME"
  echo "  profile: $PROFILE_NAME"

  if ! command -v "${HERMES_BIN:-hermes}" >/dev/null 2>&1; then
    echo "  missing: hermes CLI (set HERMES_BIN or install Hermes)"
    ok=false
  else
    echo "  hermes: $("${HERMES_BIN:-hermes}" --version 2>/dev/null || echo found)"
  fi

  if [ ! -f "$OVERLAY_DIR/distribution.yaml" ] || [ ! -f "$OVERLAY_DIR/SOUL.md" ]; then
    echo "  missing: overlay distribution.yaml or SOUL.md"
    ok=false
  fi

  if [ ! -f "$config_file" ]; then
    echo "  profile: not synced yet (run choomfie sync)"
    ok=false
  else
    echo "  profile: synced"

    if yaml_section_bool_is_true "$config_file" "sessions" "auto_prune"; then
      echo "  sessions auto-prune: enabled"
    else
      echo "  sessions auto-prune: disabled or missing"
      ok=false
    fi

    retention_days="$(yaml_section_number_value "$config_file" "sessions" "retention_days")"
    if [[ "$retention_days" =~ ^[0-9]+$ ]] && [ "$retention_days" -le 45 ]; then
      echo "  session retention: ${retention_days} days"
    else
      echo "  session retention: missing or above 45 days"
      ok=false
    fi

    if yaml_section_bool_is_true "$config_file" "compression" "enabled"; then
      echo "  compression: enabled"
    else
      echo "  compression: missing or disabled"
      ok=false
    fi

    if grep -Eq '^[[:space:]]*-[[:space:]]*(memory|session_search|todo|file|terminal|code_execution)([[:space:]]*#.*)?$' "$config_file"; then
      echo "  tools: includes stateful/core tools"
    else
      echo "  tools: limited; verify this is intentional for Choomfie"
    fi
  fi

  if [ -f "$env_file" ]; then
    if grep -Eq '^(DISCORD_BOT_TOKEN|DISCORD_TOKEN)=.+[^[:space:]]' "$env_file"; then
      echo "  discord token: configured"
    else
      echo "  discord token: missing in profile .env"
      ok=false
    fi

    if grep -Eq '^DISCORD_ALLOWED_USERS=.+[^[:space:]]' "$env_file"; then
      echo "  discord allowlist: configured"
    elif grep -Eq '^(DISCORD_ALLOW_ALL|DISCORD_OPEN_ACCESS)=true' "$env_file"; then
      echo "  discord allowlist: open access enabled"
      ok=false
    else
      echo "  discord allowlist: missing"
      ok=false
    fi
  else
    echo "  profile .env: missing (copy .env.EXAMPLE)"
    ok=false
  fi

  if [ -x "$OVERLAY_DIR/scripts/token-budget.sh" ]; then
    echo "  token budget watcher: installed"
  else
    echo "  token budget watcher: missing"
    ok=false
  fi

  if [ "$ok" = true ]; then
    echo "Doctor passed."
  else
    echo "Doctor found setup gaps."
    return 1
  fi
}

sync_overlay() {
  "$OVERLAY_DIR/scripts/sync.sh" "$OVERLAY_DIR" "$HERMES_HOME" "$PROFILE_NAME"
}

cmd="${1:-gateway}"
case "$cmd" in
  -h|--help|help)
    usage
    ;;
  claude-code|claude)
    shift
    claude_code "$@"
    ;;
  legacy)
    echo "Error: 'choomfie legacy' has been removed. Use 'choomfie claude-code'." >&2
    exit 2
    ;;
  doctor)
    doctor
    ;;
  configure-discord)
    shift
    configure_discord "$@"
    ;;
  sync|update)
    sync_and_harden
    ;;
  reset)
    shift
    if ! command -v bun >/dev/null 2>&1; then
      echo "Error: 'bun' is required for choomfie reset." >&2
      exit 1
    fi
    exec bun "$ROOT_DIR/packages/core/scripts/reset.ts" "$@"
    ;;
  start)
    shift
    sync_and_harden
    hermes_cmd gateway start "$@"
    ;;
  install|setup|migrate-legacy)
    shift
    sync_and_harden
    hermes_cmd gateway "$cmd" "$@"
    ;;
  status|uninstall|list)
    shift
    gateway_cmd "$cmd" "$@"
    ;;
  restart)
    shift
    sync_and_harden
    hermes_cmd gateway restart "$@"
    ;;
  stop)
    shift
    echo "Note: 'choomfie stop' targets the Choomfie profile gateway. Flags such as --all or --system can broaden scope." >&2
    gateway_cmd stop "$@"
    ;;
  chat)
    shift
    sync_overlay
    hermes_cmd chat "$@"
    ;;
  gateway|"")
    shift || true
    sync_and_harden
    hermes_cmd gateway start "$@"
    ;;
  *)
    sync_overlay
    hermes_cmd "$@"
    ;;
esac
