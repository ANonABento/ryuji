# Choomfie-Hermes profile distribution environment.
# Copy to .env inside the installed profile and fill in local secrets.

API_SERVER_KEY=
API_SERVER_HOST=127.0.0.1
API_SERVER_PORT=8642
API_SERVER_ENABLED=true
API_SERVER_MODEL_NAME=choomfie

DISCORD_TOKEN=

# Pick at least one Hermes-supported model provider.
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
OLLAMA_API_KEY=

# Choomfie local choices.
HERMES_PROVIDER=ollama
HERMES_MODEL=hermes-agent
HERMES_ALLOW_GLOBAL_CONFIG_WRITE=0
HERMES_ALLOW_UNSAFE_TOOLS=0
HERMES_LOG_LEVEL=info

