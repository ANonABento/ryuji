# Copy to .env in the Choomfie Hermes profile and fill in local secrets.
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USERS=

# Configure whichever Hermes provider you use.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional: path to the read-only legacy Choomfie SQLite database for migration tools.
CHOOMFIE_LEGACY_DB=
