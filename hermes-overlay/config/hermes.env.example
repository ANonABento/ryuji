# Choomfie-Hermes local environment.
# Copy to .env.hermes and edit locally. Do not commit real secrets.

# Hermes executable. Can be an absolute path, a wrapper script, or a command on PATH.
HERMES_BIN=hermes

# Pin the upstream Hermes version or ref for install/update scripts.
HERMES_VERSION=main
HERMES_REPO=https://github.com/NousResearch/hermes-agent.git

# Choomfie-specific Hermes state. This keeps the overlay from mutating global Hermes state.
CHOOMFIE_HERMES_HOME=${HOME}/.choomfie-hermes

# Overlay paths. Defaults are computed by scripts, but explicit values are useful for services.
CHOOMFIE_HERMES_OVERLAY=
HERMES_CONFIG=
HERMES_PROFILE=choomfie

# Gateway/API defaults.
API_SERVER_HOST=127.0.0.1
API_SERVER_PORT=8642
API_SERVER_ENABLED=true
API_SERVER_MODEL_NAME=choomfie

# Set this before sharing Hermes with Choomfie shell or Discord.
API_SERVER_KEY=

# Provider/model values are placeholders; set them to the local Hermes provider names you use.
HERMES_PROVIDER=ollama
HERMES_MODEL=hermes-agent

# Safe-by-default runtime behavior.
HERMES_AUTO_UPDATE=0
HERMES_ALLOW_GLOBAL_CONFIG_WRITE=0
HERMES_ALLOW_UNSAFE_TOOLS=0
HERMES_LOG_LEVEL=info
