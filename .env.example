# Discord Bot Token (from discord.dev)
DISCORD_TOKEN=
DISCORD_CLIENT_ID=

# Anthropic API key (required for /translate and the translate MCP tool;
# also used as fallback description provider for /imagine when OpenAI is unset)
ANTHROPIC_API_KEY=
ANTHROPIC_TRANSLATE_MODEL=claude-3-5-haiku-latest
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Image generation (optional — /imagine uses a local SVG fallback without this)
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024

# Voice plugin (optional — only needed if voice plugin enabled)
GROQ_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_EN=
ELEVENLABS_VOICE_JA=
