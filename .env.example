# Discord Bot Token (from discord.dev)
DISCORD_TOKEN=
DISCORD_CLIENT_ID=

# No Anthropic API key needed — Choomfie uses Claude Code CLI via plugin system (Max plan)

# Image generation (optional — /imagine uses a local SVG fallback without this)
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Voice plugin (optional — only needed if voice plugin enabled)
GROQ_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_EN=
ELEVENLABS_VOICE_JA=
